# Konfigurasi Supabase — salin file ini menjadi .env lalu isi nilainya.
# Ambil dari Supabase Dashboard → Project Settings → API.
# Gunakan HANYA anon/public key di sini (aman dikirim ke client, dilindungi RLS).
# JANGAN pernah menaruh service_role key di file yang dipakai client.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
